{
	"name": "drivemate-admin",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run",
		"test:pact": "vitest run --config vitest.pact.config.ts",
		"test:watch": "vitest",
		"preview": "vite preview",
		"typecheck:pact": "tsc -p tsconfig.pact.json --noEmit"
	},
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"axios": "^1.16.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router-dom": "^7.13.1",
		"recharts": "^3.8.1",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@pact-foundation/pact": "^16.5.0",
		"@repo/pact-matchers": "file:../luyen-thi-lai-xe-microservices/packages/pact-matchers",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^24.13.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.4.0",
		"jsdom": "^29.1.1",
		"prettier": "^3.8.4",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^8.0.0",
		"vitest": "^4.1.9"
	}
}
